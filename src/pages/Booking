          <p className="mt-3 text-slate-400">
            Reserve your surf experience with TIDE X Surf Bali.
          </p>
        </header>

        <form
          onSubmit={handleSubmit}
          className="space-y-6 rounded-3xl bg-slate-900 p-8 shadow-xl"
        >
          <div>
            <label className="mb-2 flex items-center gap-2 text-sm">
              <User size={18} />
              Full Name
            </label>

            <input
              className="w-full rounded-xl bg-slate-800 p-3 outline-none"
              type="text"
              name="name"
              value={form.name}
              onChange={handleChange}
              required
            />
          </div>

          <div>
            <label className="mb-2 flex items-center gap-2 text-sm">
              <Mail size={18} />
              Email
            </label>

            <input
              className="w-full rounded-xl bg-slate-800 p-3 outline-none"
              type="email"
              name="email"
              value={form.email}
              onChange={handleChange}
            />
          </div>

          <div>
            <label className="mb-2 flex items-center gap-2 text-sm">
              <Phone size={18} />
              Phone / WhatsApp
            </label>

            <input
