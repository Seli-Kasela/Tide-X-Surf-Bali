  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();

    alert("Booking submitted successfully!");

    console.log(form);
  };

  return (
    <main className="min-h-screen bg-slate-950 text-white">
      <div className="mx-auto max-w-3xl px-6 py-12">

        <header className="mb-10 text-center">
